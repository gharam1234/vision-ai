# 환경 설정 예시
# 이 파일을 .env로 복사하여 사용하세요

# ===== 앱 전체 설정 =====
APP_CAMERA_ID=cam-001
APP_SHOW_DISPLAY=true
APP_LOG_LEVEL=INFO

# ===== 영상 소스 =====
VIDEO_SOURCE=sample.mp4
VIDEO_WIDTH=1280
VIDEO_HEIGHT=720
VIDEO_FPS_LIMIT=30
VIDEO_LOOP=true

# ===== YOLO 감지 =====
DETECTOR_MODEL_PATH=yolo26s.pt
DETECTOR_CONFIDENCE_THRESHOLD=0.3
DETECTOR_IOU_THRESHOLD=0.45
DETECTOR_DEVICE=auto
DETECTOR_IMG_SIZE=640

# ===== ByteTrack 추적 =====
TRACKER_TRACK_THRESH=0.25
TRACKER_TRACK_BUFFER=30
TRACKER_MATCH_THRESH=0.8

# ===== 위험구역 =====
ZONE_POLL_INTERVAL=30

# ===== 이벤트 전송 =====
EVENT_COOLDOWN_SECONDS=10.0
EVENT_SAVE_SNAPSHOTS=true
EVENT_SNAPSHOT_DIR=snapshots

# ===== 백엔드 API =====
API_BASE_URL=http://localhost:8000
API_WS_URL=ws://localhost:8000/ws/events
API_TIMEOUT=5.0
API_RETRY_COUNT=3
# API_KEY=your-api-key-here

# ===== 감도 및 제스처 튜닝 설정 (오탐/미탐 튜닝용) =====
# 위험 감지 판정에 필요한 최소 연속 프레임 수 (기본: 3, 오탐 차단 극대화하려면 10~15 추천)
EVENT_ENTER_THRESHOLD_FRAMES=20
# 위험 해제 판정에 필요한 최소 연속 프레임 수 (기본: 5)
EVENT_EXIT_THRESHOLD_FRAMES=5
# 손 흔들기 최소 진폭 비율 (어깨 너비 대비, 기본: 0.15)
EVENT_WAVING_AMPLITUDE_RATIO=0.30
# 손 흔들기 최소 방향 전환 횟수 (기본: 2)
EVENT_WAVING_DIRECTION_CHANGES=2
# 동시 감지 가능한 최대 작업자 수 (최대 포즈 개수, 기본: 5)
EVENT_POSE_MAX_NUM=5
